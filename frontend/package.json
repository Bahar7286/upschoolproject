    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^3.0.5",
    "jsdom": "^26.0.0",
    "@testing-library/react": "^16.3.0"
  }
