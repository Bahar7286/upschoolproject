DATABASE_URL=postgresql+asyncpg://historial:historial_dev_password@localhost:5432/historial_go
JWT_SECRET_KEY=change-me-in-production-min-32-chars
FRONTEND_URL=http://localhost:5173

# CORS (canlı frontend URL — virgülle ayırın)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Stripe (üretim ödemesi — yoksa demo kart akışı kullanılır)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- LLM (proje kabul kriteri: çekirdek mantıkta API) ---
# Sağlayıcı: openrouter | huggingface | gemini
# Hız için önerilen: gemini (gemini-2.0-flash) veya openrouter + ücretli hızlı model
LLM_PROVIDER=gemini

# Google Gemini (önerilen — hızlı asistan ve rota önerisi)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter — https://openrouter.ai/keys (alternatif)
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=google/gemma-4-31b-it:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Hugging Face — hızlı yedek veya birincil sağlayıcı (https://huggingface.co/settings/tokens)
# HUGGINGFACE_API_KEY=hf_...
# HUGGINGFACE_MODEL=google/gemma-2-2b-it

LLM_TIMEOUT_SECONDS=30

# Ortam: development | production
ENVIRONMENT=development
UPLOAD_DIR=./uploads

# SMTP (şifre sıfırlama e-postası — production önerilir)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@yourdomain.com
# SMTP_USE_TLS=true

# Brevo HTTP API (SMTP timeout olursa alternatif)
# BREVO_API_KEY=xb5p... (Brevo panel -> API Keys)
# BREVO_BASE_URL=https://api.brevo.com

# OSM Overpass (POI senkronu — admin tetikler)
# OVERPASS_BASE_URL=https://overpass.kumi.systems/api
# OVERPASS_USER_AGENT=HistorialGO/1.0 (contact: you@example.com)

# Google Cloud — Maps JavaScript (frontend), Places API (New) + Routes API (backend proxy)
# Console: Billing + Maps JavaScript API + Places API (New) + Routes API
# GOOGLE_PLACES_API_KEY=...   # server-only, Places Nearby + Details (Nearby: max 20/istek; uygulama birleştirir)
# GOOGLE_ROUTES_API_KEY=...   # server-only (opsiyonel; yoksa Places key kullanılır)
# Frontend (.env): VITE_GOOGLE_MAPS_API_KEY=...  # HTTP referrer kısıtlı
# Anahtar rehberi: prodocs/API_KEYS_TR.md
