DATABASE_URL=postgresql+asyncpg://historial:historial_dev_password@localhost:5432/historial_go
JWT_SECRET_KEY=change-me-in-production-min-32-chars
FRONTEND_URL=http://localhost:5173

# CORS (canlı frontend URL — virgülle ayırın)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Stripe (üretim ödemesi — yoksa demo kart akışı kullanılır)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- LLM (proje kabul kriteri: çekirdek mantıkta API) ---
# Sağlayıcı: openrouter | gemini
LLM_PROVIDER=openrouter

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Google Gemini (alternatif — LLM_PROVIDER=gemini)
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash

LLM_TIMEOUT_SECONDS=45

# Ortam: development | production
ENVIRONMENT=development
UPLOAD_DIR=./uploads

# SMTP (şifre sıfırlama e-postası — production önerilir)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@yourdomain.com
# SMTP_USE_TLS=true

# Brevo HTTP API (SMTP timeout olursa alternatif)
# BREVO_API_KEY=xb5p... (Brevo panel -> API Keys)
# BREVO_BASE_URL=https://api.brevo.com
