# Historial-GO — kök örnek şablon (gerçek anahtarları buraya YAZMAYIN)
# Kullanım:
#   backend  → bu dosyadan backend/.env oluşturun
#   frontend → frontend/.env.example dosyasını frontend/.env olarak kopyalayın

# ─── Backend (backend/.env) ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://historial:historial_dev_password@localhost:5432/historial_go
JWT_SECRET_KEY=change-me-in-production-min-32-characters-long
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM — proje kabul kriteri (OpenRouter veya Gemini)
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
LLM_TIMEOUT_SECONDS=45

# Stripe (opsiyonel — yoksa demo kart akışı)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ─── Frontend (frontend/.env) ─────────────────────────────────
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_GOOGLE_MAPS_API_KEY=

# ─── Production / SMTP (backend) ────────────────────────────────
# ENVIRONMENT=production
# UPLOAD_DIR=/app/uploads
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@yourdomain.com
# SMTP_USE_TLS=true
